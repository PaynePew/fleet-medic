#!/bin/sh
# fleet-medic ops-ro forced-command dispatcher (ADR-0002 read-only key).
#
# authorized_keys pins this via command="/usr/local/bin/ops-ro-guard"; the
# client's real command arrives in $SSH_ORIGINAL_COMMAND. This is a
# safety-critical boundary — it is version-controlled and tested here
# (tests/test_ops_ro_guard.py), not left to live only beside authorized_keys
# on the box (arch-review 2026-07-18, ADR-0003).
#
# Note on the channel: `ssh ... -- <argv>` flattens argv into one space-joined
# string with no re-quoting, and this guard re-parses it via `sh -c`. So the
# read tools must send commands with NO shell metacharacters and NO
# whitespace-bearing arguments (e.g. use `::` field separators in --format,
# never a literal TAB) — otherwise a value word-splits here. See ADR-0003.
#
# Set OPS_RO_GUARD_CHECK=1 to validate-only: print the decision and exit
# without running anything (the tests use this so they never invoke docker).
cmd="${SSH_ORIGINAL_COMMAND:-}"

reject() { echo "ops-ro: $1" >&2; exit 1; }
allow() {
  if [ -n "${OPS_RO_GUARD_CHECK:-}" ]; then echo "ALLOW"; exit 0; fi
  # -f: no glob may expand at execution that the checks above never saw.
  exec /bin/sh -f -c "$cmd"
}

# No interactive shell: an empty command means someone ran `ssh ops-ro@box`.
[ -n "$cmd" ] || reject "interactive shell is not permitted"

# Reject anything that could chain or expand into a second command remotely,
# including glob characters — no read tool sends one, and a glob would
# re-expand unseen when `sh -c` runs the command (same as ops-rw-guard).
case "$cmd" in
  *[\;\|\&\$\`\<\>\(\)\*\?\[]*) reject "shell metacharacter rejected" ;;
esac

# Reject quotes and backslash: allow()'s `sh -c` strips them before execution,
# so a quoted word validated here reconstructs to something else when it runs
# (same disagreement ops-rw-guard closes). No read tool sends them.
case "$cmd" in
  *\"* | *\\* | *\'*) reject "quote or backslash rejected" ;;
esac

# A newline/tab/CR inside the flattened command could smuggle a second line
# past the allowlist prefixes below (`sh -c` runs every line) — reject
# outright (same check as ops-rw-guard).
nl=$(printf '\nx'); nl=${nl%x}
tab=$(printf '\tx'); tab=${tab%x}
cr=$(printf '\rx'); cr=${cr%x}
case "$cmd" in
  *"$nl"* | *"$tab"* | *"$cr"*) reject "control whitespace rejected" ;;
esac

# Read-only allowlist: only these diagnostic prefixes. Tighten to exactly what
# the ops-mcp read tools send before relying on this in production.
case "$cmd" in
  "docker logs "*|"docker inspect "*|"docker ps"*|"docker system df"*|"df "*|"du "*) allow ;;
  *) reject "command not in read-only allowlist" ;;
esac
